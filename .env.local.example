# Copy file này thành .env.local và điền thông tin

NEXT_PUBLIC_SITE_URL=https://lifefun.vn

# === X (Twitter) API v2 ===
# Lấy Bearer Token tại: https://developer.x.com/en/portal/dashboard
# Cần tier "Basic" ($100/tháng) để dùng Recent Search API.
# Nếu không cấu hình, /api/x-feed sẽ trả về mock data tự động.
X_BEARER_TOKEN=

# === TradingView ===
# Widget ticker tape / chart / screener / heatmap dùng embed script công khai,
# KHÔNG cần API key. Chỉ cần key nếu nâng cấp lên TradingView Charting Library (trả phí).
# TRADINGVIEW_API_KEY=

# === Giá Crypto ===
# /api/prices dùng CoinGecko Public API (miễn phí, có rate limit ~10-30 req/phút).
# Nếu cần tần suất cao hơn, đăng ký CoinGecko Pro và set:
# COINGECKO_API_KEY=

# === Tin tức RSS ===
# /api/news đọc trực tiếp các RSS feed công khai (CafeF, Vietstock, CoinDesk, Cointelegraph...)
# Không cần API key. Có thể chỉnh danh sách nguồn trong src/lib/rss.ts

# ============================================================
# === WEB3: Kết nối ví, đăng nhập SIWE, Portfolio, Swap, NFT ===
# ============================================================

# --- WalletConnect (bắt buộc để hiện QR code kết nối ví di động) ---
# Đăng ký Project ID miễn phí tại: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Session SIWE (Sign-In with Ethereum) ---
# Tạo chuỗi ngẫu nhiên >= 32 ký tự: openssl rand -base64 32
SESSION_SECRET=

# --- RPC node cho EVM (đọc số dư, kiểm tra NFT) ---
# Mặc định dùng RPC công khai của viem (rate-limited). Production nên dùng:
# Alchemy: https://www.alchemy.com | Infura: https://www.infura.io
NEXT_PUBLIC_EVM_RPC_URL=

# --- Solana RPC ---
# Mặc định: clusterApiUrl("mainnet-beta") (rate-limited, chỉ dùng dev/demo).
# Production nên dùng Helius / QuickNode / Triton.
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# --- Portfolio: danh sách token ERC-20/SPL đầy đủ (tuỳ chọn) ---
# Chọn 1 trong các API sau để mở rộng /api/portfolio:
# ALCHEMY_API_KEY=
# COVALENT_API_KEY=
# MORALIS_API_KEY=
# HELIUS_API_KEY=

# --- Swap: 1inch API cho EVM (Jupiter cho Solana không cần key) ---
# Đăng ký tại: https://portal.1inch.dev
ONEINCH_API_KEY=

# --- Token-gating / Membership NFT ---
# Địa chỉ smart contract ERC-721/ERC-1155 trên Ethereum mainnet.
# Để trống nếu chưa triển khai NFT thành viên (/api/membership sẽ trả isMember: false an toàn).
MEMBERSHIP_NFT_CONTRACT=
MEMBERSHIP_MIN_BALANCE=1
